---
//import background from "../assets/background.svg";

const name = "Nicolás Bazaes";
const profession = "Fullstack developer and sysadmin";
const introCommand = "login guest";
const email = "contact@nbazaes.dev";
const infoLines = [
    "Welcome to nbazaes.dev v1.0",
    `This is ${name}'s website`,
    `Role: ${profession}`,
];

// Timing constants (all in seconds)
const typingDuration = 0.9; // how long "login guest" takes to type
const postTypingPause = 0.4; // pause after typing before output appears
const lineDelay = 0.18; // gap between each info line appearing
const postOutputPause = 0.3; // pause after last line before prompt appears

// When does each info line start fading in?
const lineDelays = infoLines.map(
    (_, i) => typingDuration + postTypingPause + i * lineDelay,
);

// When does the real input prompt appear?
const promptDelay =
    lineDelays[lineDelays.length - 1] + lineDelay + postOutputPause;
---

<div id="container">
    <main>
        <section id="hero">
            <!-- Animated "login guest" line -->
            <p class="terminal-row intro-row">
                <span class="prompt-prefix">User@Portfolio:~$</span>
                <span
                    class="animated-command"
                    style={`--chars: ${introCommand.length}; --typing-duration: ${typingDuration}s;`}
                >
                    {introCommand}
                </span>
            </p>

            <!-- Info lines, each fading in after the previous -->
            <div class="terminal-body">
                {
                    infoLines.map((line, i) => (
                        <p
                            class="terminal-row info-line"
                            style={`--line-delay: ${lineDelays[i].toFixed(2)}s;`}
                        >
                            {line}
                        </p>
                    ))
                }
            </div>

            <!-- Real input prompt, appears after all info lines -->
            <div id="terminal-output"></div>
            <div
                class="command-line"
                style={`--prompt-delay: ${promptDelay.toFixed(2)}s;`}
            >
                <span class="prompt-prefix">guest@nbazaes:~$</span>
                <input
                    type="text"
                    id="terminal-input"
                    placeholder="type 'help' to see available commands"
                    autocomplete="off"
                    spellcheck="false"
                />
            </div>
        </section>
    </main>
</div>

<script>
    const input = document.querySelector<HTMLInputElement>("#terminal-input");
    const commandLine = document.querySelector<HTMLElement>(".command-line");
    const output = document.querySelector<HTMLElement>("#terminal-output");
    const promptDelay = Number.parseFloat(
        commandLine?.style.getPropertyValue("--prompt-delay") ?? "0",
    );

    const promptText = "guest@nbazaes:~$";
    const localeStorageKey = "nbazaes-locale";

    type Locale = "en" | "es";

    const i18n = {
        en: {
            placeholder: "type 'help' to see available commands",
            infoLines: [
                "Welcome to nbazaes.dev v1.0",
                "This is Nicolás Bazaes's website",
                "Role: Fullstack developer and sysadmin",
            ],
            availableCommands: "Available commands:",
            helpLines: [
                "- help: see available commands",
                "- clear: clear the terminal output",
                "- readme: display information about me",
                "- github: view my GitHub portfolio",
                "- contact: view contact information",
                "- gui: switch to the traditional GUI version of the site",
            ],
            aboutMe: "About me:",
            readmeLines: [
                "My name is Nicolás Bazaes, and I'm a fullstack developer and sysadmin based in Chile, with a passion for technology and problem-solving.",
                "I build fullstack products in frameworks like React, Astro, Django, and more.",
                "However, my true passion lies in backend development and system administration where I enjoy optimizing server performance and ensuring robust infrastructure.",
                "I like to use Docker to deploy my projects, and I love to host my own servers to tinker with different setups and configurations.",
                "Also, I am a full Linux user and enthusiast, and I enjoy exploring the command line and all the powerful tools it offers.",
            ],
            githubPortfolio: "GitHub portfolio:",
            githubLandingDescription:
                "The source code for this very website, built with Astro and vanilla JS.",
            githubDiscursantesDescription:
                "A fullstack web app built with React, Django, and Docker, built for the management of a local church's speakers.",
            githubWebconstDescription:
                "A full-stack Django prototype for a local artist to showcase and sell digital art.",
            githubBazposDescription:
                "A full point-of-sale system built with Django and Bootstrap including inventory management, reports, user management, supplier management and invoicing.",
            emailLabel: "email:",
            openingGui: "Opening GUI view...",
            sudoMessage:
                "guest is not in the sudoers file. This incident will be reported.",
            rmRootLines: [
                "rm: it is dangerous to operate recursively on '/'.",
                "By default, rm uses --preserve-root to prevent deleting the system root.",
            ],
            commandNotFound: "Command not found:",
            typeHelp: "Type 'help' to see available commands.",
        },
        es: {
            placeholder: "escribe 'help' para ver los comandos disponibles",
            infoLines: [
                "Bienvenido a nbazaes.dev v1.0",
                "Este es el sitio web de Nicolás Bazaes",
                "Rol: Desarrollador fullstack y administrador de sistemas",
            ],
            availableCommands: "Comandos disponibles:",
            helpLines: [
                "- help: ver los comandos disponibles",
                "- clear: limpiar la salida del terminal",
                "- readme: mostrar información sobre mí",
                "- github: ver mi portafolio de GitHub",
                "- contact: ver información de contacto",
                "- gui: cambiar a la versión GUI tradicional del sitio",
            ],
            aboutMe: "Sobre mí:",
            readmeLines: [
                "Mi nombre es Nicolás Bazaes y soy desarrollador fullstack y administrador de sistemas en Chile, con pasión por la tecnología y la resolución de problemas.",
                "Construyo productos fullstack con frameworks como React, Astro, Django y más.",
                "Sin embargo, mi verdadera pasión está en el desarrollo backend y la administración de sistemas, donde disfruto optimizando el rendimiento de servidores y asegurando una infraestructura robusta.",
                "Me gusta usar Docker para desplegar mis proyectos, y me encanta alojar mis propios servidores para experimentar con distintas configuraciones.",
                "También soy usuario y entusiasta de Linux, y disfruto explorar la línea de comandos y todas las herramientas poderosas que ofrece.",
            ],
            githubPortfolio: "Portafolio de GitHub:",
            githubLandingDescription:
                "El código fuente de este mismo sitio, construido con Astro y JavaScript vanilla.",
            githubDiscursantesDescription:
                "Una aplicación web fullstack construida con React, Django y Docker para la gestión de predicadores de una iglesia local.",
            githubWebconstDescription:
                "Un prototipo full-stack en Django para que un artista local muestre y venda arte digital.",
            githubBazposDescription:
                "Un sistema de punto de venta completo construido con Django y Bootstrap, con inventario, reportes, gestión de usuarios, proveedores y facturación.",
            emailLabel: "correo:",
            openingGui: "Abriendo vista GUI...",
            sudoMessage:
                "guest no está en el archivo sudoers. Este incidente será reportado.",
            rmRootLines: [
                "rm: es peligroso operar de forma recursiva sobre '/'.",
                "Por defecto, rm usa --preserve-root para evitar borrar la raíz del sistema.",
            ],
            commandNotFound: "Comando no encontrado:",
            typeHelp: "Escribe 'help' para ver los comandos disponibles.",
        },
    } as const;

    const detectLocale = (): Locale => {
        try {
            const storedLocale = window.localStorage.getItem(localeStorageKey);
            if (storedLocale === "en" || storedLocale === "es") {
                return storedLocale;
            }
        } catch {
            // Ignore storage access errors (private mode, policies, etc.)
        }

        const browserLocales = [
            ...(navigator.languages ?? []),
            navigator.language,
        ]
            .filter(Boolean)
            .map((value) => value.toLowerCase());

        const detectedLocale: Locale = browserLocales.some((value) =>
            value.startsWith("es"),
        )
            ? "es"
            : "en";

        try {
            window.localStorage.setItem(localeStorageKey, detectedLocale);
        } catch {
            // Ignore storage access errors (private mode, policies, etc.)
        }

        return detectedLocale;
    };

    const locale = detectLocale();
    const t = i18n[locale];

    if (input) {
        input.placeholder = t.placeholder;
    }

    const infoLineElements = document.querySelectorAll<HTMLElement>(
        ".terminal-body .info-line",
    );
    infoLineElements.forEach((lineElement, index) => {
        lineElement.textContent = t.infoLines[index] ?? lineElement.textContent;
    });

    type OutputItem = string | HTMLElement;
    type CommandHandler = (args: string[]) => OutputItem[];

    // Helper: create a styled <a> link for use inside commands.
    const link = (text: string, href: string): HTMLAnchorElement => {
        const a = document.createElement("a");
        a.href = href;
        a.textContent = text;
        a.target = "_blank";
        a.rel = "noopener noreferrer";
        a.className = "terminal-link";
        return a;
    };

    // Template: add your commands here.
    const commands: Record<string, CommandHandler> = {
        help: () => [
            t.availableCommands,
            ...t.helpLines,
        ],
        clear: () => {
            if (output) {
                output.innerHTML = "";
            }
            return [];
        },
        readme: () => [
            t.aboutMe,
            ...t.readmeLines,
        ],
        github: () => [
            link(t.githubPortfolio, "https://github.com/nbazaes"),
            link("landing-astro:", "https://github.com/nbazaes/landing-astro"),
            t.githubLandingDescription,
            link("discursantes_react:", "https://github.com/nbazaes/discursantes_react"),
            t.githubDiscursantesDescription,
            link("webconstAD:", "https://github.com/nbazaes/webconstAD"),
            t.githubWebconstDescription,
            link("django-bazpos:", "https://github.com/nbazaes/django-bazpos"),
            t.githubBazposDescription,
        ],
        contact: () => [
            t.emailLabel,
            link("contact@nbazaes.dev", "mailto:contact@nbazaes.dev"),
        ],
        gui: () => {
            window.location.href = "/index-alt";
            return [t.openingGui];
        },
        sudo: () => [t.sudoMessage],
        "rm -rf /": () => [...t.rmRootLines],
    };

    const appendOutput = (lines: OutputItem[]) => {
        if (!output) return;

        const fragment = document.createDocumentFragment();
        for (const line of lines) {
            const row = document.createElement("p");
            row.className = "output-row terminal-row";
            if (typeof line === "string") {
                row.textContent = line;
            } else {
                row.appendChild(line);
            }
            fragment.appendChild(row);
        }

        output.appendChild(fragment);
    };

    const appendPromptCommand = (command: string) => {
        if (!output) return;

        const row = document.createElement("p");
        row.className = "output-row terminal-row";

        const prefix = document.createElement("span");
        prefix.className = "prompt-prefix";
        prefix.textContent = promptText;

        const commandText = document.createTextNode(` ${command}`);

        row.append(prefix, commandText);
        output.appendChild(row);
    };

    const scrollToLatest = () => {
        window.requestAnimationFrame(() => {
            commandLine?.scrollIntoView({ block: "end", behavior: "smooth" });
        });
    };

    const runCommand = (rawValue: string) => {
        const trimmed = rawValue.trim();
        if (!trimmed) return;

        appendPromptCommand(trimmed);

        const normalized = trimmed.toLowerCase();

        // First try an exact command match (supports multi-word commands).
        let handler = commands[normalized];
        let name = normalized;
        let args: string[] = [];

        // Fallback to command + args matching.
        if (!handler) {
            [name, ...args] = normalized.split(/\s+/);
            handler = commands[name];
        }

        if (!handler) {
            appendOutput([
                `${t.commandNotFound} ${trimmed}`,
                t.typeHelp,
            ]);
            scrollToLatest();
            return;
        }

        const result = handler(args);
        appendOutput(result);
        scrollToLatest();
    };

    // Focus the input once the prompt has appeared
    window.setTimeout(() => {
        input?.focus();
        scrollToLatest();
    }, promptDelay * 1000);

    input?.addEventListener("keydown", (event) => {
        if (event.key !== "Enter") return;
        event.preventDefault();
        runCommand(input.value);
        input.value = "";
        input.removeAttribute("placeholder");
    });
</script>

<style>
    :root {
        --terminal-fg: #f1f0f4;
    }

    #background {
        position: absolute;
        z-index: -1;
        filter: blur(100px);
    }

    #container {
        font-family:
            "Cascadia Code", "Cascadia Mono", ui-monospace, Menlo, Consolas,
            monospace;
        min-height: 100vh;
        border: 2px solid #c7b5ff;
        margin: 1%;
        border-radius: 1%;
    }

    main {
        min-height: 100vh;
        display: flex;
        align-items: flex-start;
        justify-content: flex-start;
        padding: clamp(20px, 5vw, 60px);
    }

    #hero {
        width: min(100%, 920px);
    }

    .terminal-body {
        padding: 0;
    }

    .terminal-row {
        margin: 0;
        color: var(--terminal-fg);
        font-size: clamp(0.95rem, 1.9vw, 1.35rem);
        line-height: 1.7;
        letter-spacing: 0.02em;
    }

    /* ── "login guest" typing row ── */
    .intro-row {
        display: flex;
        align-items: baseline;
        gap: 0.6ch;
        white-space: nowrap;
    }

    :global(.prompt-prefix) {
        flex: 0 0 auto;
    }

    .animated-command {
        display: inline-block;
        overflow: hidden;
        white-space: nowrap;
        /* start fully clipped, animate to fully visible */
        clip-path: inset(0 100% 0 0);
        animation: typing var(--typing-duration) steps(var(--chars), end)
            forwards;
    }

    /* Blinking cursor on the typed command — disappears when typing ends */
    .animated-command::after {
        content: "";
        display: inline-block;
        width: 0.65ch;
        height: 1.1em;
        margin-left: 0.12ch;
        vertical-align: -0.15em;
        background: var(--terminal-fg);
        /* fade out exactly when typing finishes, then stay hidden */
        animation: cursor-stop var(--typing-duration) steps(1, end) forwards;
    }

    /* ── Info lines ── */
    .info-line {
        opacity: 0;
        animation: line-appear 0.15s ease-out forwards;
        animation-delay: var(--line-delay);
    }

    /* ── Real prompt + input ── */
    .command-line {
        display: flex;
        align-items: baseline;
        gap: 0.6ch;
        margin-top: 4px;
        opacity: 0;
        animation: line-appear 0.15s ease-out forwards;
        animation-delay: var(--prompt-delay);
    }

    #terminal-input {
        min-width: 16ch;
        width: min(100%, 32rem);
        background: transparent;
        border: none;
        color: var(--terminal-fg);
        font-family: inherit;
        font-size: clamp(0.95rem, 1.9vw, 1.35rem);
        line-height: 1.7;
        letter-spacing: 0.02em;
        outline: none;
        flex-grow: 1;
        caret-color: var(--terminal-fg);
        animation: blink-caret 1.05s steps(1, end) infinite;
    }

    #terminal-input::placeholder {
        color: rgba(241, 240, 244, 0.55);
    }

    #terminal-output {
        color: var(--terminal-fg);
        font-size: clamp(0.95rem, 1.9vw, 1.35rem);
    }

    .output-row {
        line-height: 1;
        color: #c7b5ff;
        font-weight: 100;
    }

    :global(.terminal-link),
    :global(.terminal-link:visited) {
        color: var(--terminal-fg);
        text-decoration: underline;
        text-underline-offset: 3px;
        transition: color 0.15s;
    }

    :global(.terminal-link:hover) {
        color: #c7b5ff;
    }

    :global(.prompt-prefix) {
        color: #c7b5ff;
        font-weight: 300;
        font-size: clamp(0.95rem, 1.9vw, 1.35rem);
    }

    /* ── Keyframes ── */

    @keyframes typing {
        to {
            clip-path: inset(0 0 0 0);
        }
    }

    /* Cursor is visible while typing, gone once done */
    @keyframes cursor-stop {
        0% {
            opacity: 1;
        }
        99% {
            opacity: 1;
        }
        100% {
            opacity: 0;
        }
    }

    /* Simple fade-in for info lines and the prompt */
    @keyframes line-appear {
        from {
            opacity: 0;
            transform: translateY(4px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes blink-caret {
        0%,
        49% {
            caret-color: var(--terminal-fg);
        }
        50%,
        100% {
            caret-color: transparent;
        }
    }

    /* ── Mobile ── */
    @media screen and (max-width: 768px) {
        #container {
            display: flex;
            flex-direction: column;
        }

        #hero {
            width: 100%;
        }

        .intro-row,
        .command-line {
            gap: 0.45ch;
        }
    }
</style>
